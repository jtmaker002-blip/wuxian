{
  "name": "twitcanva",
  "private": true,
  "version": "0.0.0",
  "description": "TwitCanva desktop and web creative workflow app",
  "author": "OpenAiTeach",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-runner.cjs",
    "server": "node server/index.js",
    "test": "vitest run",
    "build": "vite build",
    "desktop:dev": "concurrently \"node server/index.js\" \"vite\" \"electron .\"",
    "desktop:pack": "npm run build && electron-builder",
    "preview": "vite preview",
    "preview:full": "concurrently \"node server/index.js\" \"vite preview\"",
    "setup:local-models": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'setup-local-models.bat' : 'bash setup-local-models.sh', {stdio: 'inherit'})\"",
    "verify:liblib-image-node": "node scripts/verify-liblib-image-node.cjs",
    "verify:canvas-rescue": "node scripts/verify-canvas-rescue.cjs",
    "verify:liblib-image-node:full": "npm run verify:liblib-image-node && npm test -- src/components/canvas/image-node/imageNodeUiState.test.ts src/utils/imageNodeActions.test.ts src/components/canvas/image-node/FocusSelectionOverlay.test.ts src/hooks/useConnectionDragging.test.ts src/hooks/useContextMenuHandlers.test.ts src/hooks/useImageNodeHandlers.test.ts src/hooks/useNodeManagement.test.ts src/hooks/useGeneration.test.ts server/routes/generation-image.test.js && npm run build"
  },
  "dependencies": {
    "@fal-ai/client": "^1.8.0",
    "@google/genai": "^1.32.0",
    "@langchain/core": "^1.1.4",
    "@langchain/google-genai": "^2.0.4",
    "@langchain/langgraph": "^1.0.4",
    "@lobehub/icons": "^3.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.182.0",
    "face-api.js": "^0.22.2",
    "form-data": "^4.0.5",
    "i18next": "^25.10.2",
    "lucide-react": "^0.556.0",
    "openai": "^6.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^16.6.0",
    "sharp": "^0.34.5",
    "three": "^0.182.0",
    "twitter-api-v2": "^1.28.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8",
    "express": "^5.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.twitcanva.desktop",
    "productName": "TwitCanva",
    "files": [
      "dist/**/*",
      "!dist/win-unpacked{,/**/*}",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/*.yml",
      "!dist/builder-debug.yml",
      "electron/**/*",
      "server/**/*",
      "!server/**/*.test.js",
      "library/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asarUnpack": [
      "server/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "executableName": "TwitCanva",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
